      { "name": { "ko": "물", "ja": "水" }, "amount": 150, "unit": "ml", "scaleType": "linear" },
      { "name": { "ko": "간장", "ja": "醤油" }, "amount": 2, "unit": "큰술", "scaleType": "linear" },
